# Copy to .env and fill in. See docs/notes.md "Local DB setup" and "Env vars".

# Required
DATABASE_URL=postgres://postgres:PASSWORD@localhost:15432/postgres?sslmode=disable
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# Optional (Fly sets PORT)
PORT=8081

# R2 (when PR images / user photos)
R2_ACCOUNT_ID=23acac6fd2f9179de96adf9599129074
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gym-app

# FCM (when notifications)
FCM_CREDENTIALS_PATH=path/to/service-account.json

# OpenAI (when AI layer)
OPENAI_API_KEY=
