# Copy to .env and fill in. See docs/notes.md "Local DB setup" and "Env vars".
# All vars use GYM_ prefix to avoid collisions with other projects (e.g. worklist).

# Required
GYM_DATABASE_URL=postgres://postgres:PASSWORD@localhost:15432/postgres?sslmode=disable
GYM_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# Optional (Fly sets PORT; app falls back to PORT if GYM_PORT unset)
GYM_PORT=8081

# Dev mode: enables GET /dev/token and Bearer dev:<email> auth. Never enable in production.
# GYM_DEV_MODE=true

# TLS (when both set, server uses HTTPS). For local: mkcert -install && mkcert localhost 127.0.0.1 10.0.2.2
# GYM_TLS_CERT_FILE=./certs/localhost+2.pem
# GYM_TLS_KEY_FILE=./certs/localhost+2-key.pem

# R2 (when PR images / user photos)
GYM_R2_ACCOUNT_ID=23acac6fd2f9179de96adf9599129074
GYM_R2_ACCESS_KEY_ID=
GYM_R2_SECRET_ACCESS_KEY=
GYM_R2_BUCKET=gym-app

# FCM (when notifications)
GYM_FCM_CREDENTIALS_PATH=path/to/service-account.json

# OpenAI (when AI layer)
GYM_OPENAI_API_KEY=

# AI throttling (protects against credit burn). See docs/ai-throttling.md
GYM_OPENAI_TEST_MODE=true
GYM_OPENAI_RATE_PER_MINUTE=10
GYM_OPENAI_DAILY_LIMIT=100
GYM_OPENAI_DALLE_DAILY_LIMIT=5
